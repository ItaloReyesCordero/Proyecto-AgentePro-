# ═══ APP ═══
APP_NAME=AgentePro
VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=cambia-esto-con-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ADMIN_SECRET_KEY=clave-secreta-admin
FRONTEND_URL=http://localhost:5173

# ═══ SUPER ADMIN (cuenta del fundador, se crea al arrancar si no existe) ═══
SUPERADMIN_EMAIL=admin@agentepro.pe
SUPERADMIN_PASSWORD=cambia-esta-clave
SUPERADMIN_NAME=Super Admin
ALLOW_FREE_SIGNUP=true

# ═══ BASE DE DATOS ═══
DATABASE_URL=postgresql+asyncpg://agentepro:agentepro_dev@localhost:5432/agentepro
DATABASE_URL_SYNC=postgresql://agentepro:agentepro_dev@localhost:5432/agentepro

# ═══ REDIS ═══
REDIS_URL=redis://localhost:6379/0

# ═══ BACKUPS DE LA BASE DE DATOS (servicio "backup" del docker-compose) ═══
# En DEV el servicio backup ya trae estos datos en el compose. En PROD (BD
# externa) defínelos aquí con los MISMOS datos de tu DATABASE_URL:
PGHOST=postgres
PGPORT=5432
PGUSER=agentepro
PGPASSWORD=agentepro_dev
PGDATABASE=agentepro
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400

# ─── Copia OFF-SITE de los backups a Supabase Storage (recomendado) ───
# Cubre el caso "se cayó/perdí el servidor entero". Si dejas estas vacías,
# la subida se omite sola y solo quedan los backups locales.
#   - SUPABASE_URL: el de tu proyecto (mismo de arriba).
#   - SUPABASE_SERVICE_KEY: la clave service_role (Settings > API). NO la anon.
#   - Crea un bucket PRIVADO llamado como SUPABASE_BACKUP_BUCKET.
SUPABASE_SERVICE_KEY=
SUPABASE_BACKUP_BUCKET=db-backups
SUPABASE_BACKUP_PREFIX=agentepro
SUPABASE_BACKUP_KEEP=30

# ═══ ANTHROPIC ═══
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
CLAUDE_MODEL_COMPLEX=claude-opus-4-8
CLAUDE_MAX_TOKENS=1024

# ═══ META WHATSAPP ═══
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN_SECRET=secreto-para-generar-tokens-por-tenant

# ═══ META INSTAGRAM ═══
META_INSTAGRAM_APP_ID=
META_INSTAGRAM_APP_SECRET=

# ═══ TWILIO ═══
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_DEFAULT_PHONE_NUMBER=+51...

# ═══ RETELL AI ═══
RETELL_API_KEY=
RETELL_DEFAULT_VOICE_ID=es-ES-ElviraNeural
RETELL_WEBHOOK_SECRET=

# ═══ HUBSPOT ═══
HUBSPOT_ACCESS_TOKEN=pat-na1-...
HUBSPOT_PORTAL_ID=

# ═══ MODAL ═══
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ═══ FAL.AI ═══
FAL_KEY=

# ═══ CULQI ═══
CULQI_PUBLIC_KEY=pk_live_...
CULQI_SECRET_KEY=sk_live_...
CULQI_WEBHOOK_SECRET=

# ═══ RESEND ═══
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@agentepro.pe

# ═══ SUPABASE ═══
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=agentepro-media

# ═══ OPENAI (Whisper para transcripción de audios) ═══
OPENAI_API_KEY=sk-...

# ═══ COBRO MANUAL (Yape/transferencia, sin pasarela) ═══
# Estos datos se muestran al negocio en su pantalla de pago para que te pague
# por adelantado. Déjalos vacíos si todavía no cobras.
PAYMENT_YAPE_NUMBER=
PAYMENT_ACCOUNT_HOLDER=
PAYMENT_BANK_ACCOUNT=
PAYMENT_CONTACT_WHATSAPP=
PAYMENT_NOTE=

# ═══ PLANES ═══ (4 planes + trial; voz=0 => plan sin llamadas)
PLAN_INICIAL_MESSAGES=200
PLAN_INICIAL_CALLS=0
PLAN_BASIC_MESSAGES=400
PLAN_BASIC_CALLS=0
PLAN_PROFESSIONAL_MESSAGES=1500
PLAN_PROFESSIONAL_CALLS=60
PLAN_ENTERPRISE_MESSAGES=4000
PLAN_ENTERPRISE_CALLS=150
PLAN_TRIAL_MESSAGES=200
PLAN_TRIAL_CALLS=10
