# ───────────────────────────────────────────────────────────────────────────
# AgentePro — imagen TODO EN UNO para Railway (un solo servicio web).
# Compila el frontend (React/Vite) y lo sirve desde el backend (FastAPI), en el
# MISMO origen, así no hay problemas de CORS ni de URLs cruzadas.
#
# En Railway, para el servicio web:
#   - Root Directory: agentepro
#   - Dockerfile Path: Dockerfile.railway
# El worker de Celery usa esta MISMA imagen con otro Start Command (ver guía).
# ───────────────────────────────────────────────────────────────────────────

# Etapa 1 — compilar el frontend
FROM node:22-alpine AS frontend
WORKDIR /fe
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install --legacy-peer-deps
COPY frontend/ ./
RUN npm run build

# Etapa 2 — backend + frontend compilado
FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# uv como gestor de dependencias (instala rápido en el entorno del sistema)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

RUN uv pip install --system --no-cache \
    "fastapi>=0.115.0" "uvicorn[standard]>=0.30.0" "sqlalchemy[asyncio]>=2.0.0" \
    "asyncpg>=0.29.0" "psycopg2-binary>=2.9.0" "alembic>=1.13.0" "pydantic>=2.7.0" "pydantic-settings>=2.3.0" \
    "anthropic>=0.40.0" "httpx>=0.27.0" "python-jose[cryptography]>=3.3.0" \
    "passlib[bcrypt]>=1.7.4" "bcrypt==4.0.1" "python-multipart>=0.0.9" "redis>=5.0.0" "celery>=5.4.0" \
    "structlog>=24.2.0" "python-dotenv>=1.0.0" "email-validator>=2.2.0" \
    "phonenumbers>=8.13.0" "cryptography>=42.0.0" "python-socketio>=5.11.0" \
    "retell-sdk>=4.0.0" "twilio>=9.0.0" "hubspot-api-client>=10.0.0" \
    "modal>=0.63.0" "resend>=2.0.0" "fal-client>=0.5.0" "tzdata>=2024.1" \
    "aiosqlite>=0.20.0"

# Usuario sin privilegios (no-root) por seguridad.
RUN useradd --create-home --uid 10001 appuser

# Código del backend (propiedad del usuario no-root)
COPY --chown=appuser:appuser backend/ /app/

# Frontend compilado (lo sirve FastAPI; ver app/main.py -> FRONTEND_DIST_DIR)
COPY --from=frontend --chown=appuser:appuser /fe/dist /app/frontend_dist
ENV FRONTEND_DIST_DIR=/app/frontend_dist

EXPOSE 8000

# A partir de aquí el contenedor corre como usuario no privilegiado.
USER appuser

# Railway inyecta $PORT. Migra la base de datos y arranca el servidor ASGI.
CMD ["sh", "-c", "alembic upgrade head && uvicorn app.main:socket_app --host 0.0.0.0 --port ${PORT:-8000}"]
