FROM node:22-alpine

WORKDIR /app

# La imagen node trae un usuario "node" sin privilegios (uid 1000). Le damos la
# propiedad de /app para poder instalar y correr Vite como no-root.
RUN chown -R node:node /app
USER node

COPY --chown=node:node package.json package-lock.json* ./
RUN npm install --legacy-peer-deps

COPY --chown=node:node . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host"]
